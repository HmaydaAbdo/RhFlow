# ─────────────────────────────────────────────────────────────────────────────
# RH Flow — Backend environment variables (template)
#
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/rh_erp_db
DB_USERNAME=rh_admin
DB_PASSWORD=change-me
POSTGRES_DB=rh_erp_db

# ── pgAdmin (docker-compose only) ────────────────────────────────────────────
PGADMIN_EMAIL=admin@rh-erp.com
PGADMIN_PASSWORD=change-me

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be a strong, random string (>= 32 chars recommended, base64 ok).
# No default is provided — app refuses to start without it.
APP_JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed front-end origins.
# Dev default: http://localhost:4200
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── MinIO (object storage — CV files) ────────────────────────────────────────
#
# IMPORTANT — Résolution des presigned URLs par docling-serve :
#
#   docling-serve tourne dans Docker et télécharge les CVs via des presigned URLs.
#   Ces URLs sont générées par Spring Boot et contiennent le hostname de MINIO_ENDPOINT.
#   Pour que docling-serve puisse les résoudre depuis son container :
#
#   ┌─ Développement local (Spring Boot sur l'hôte, infra dans Docker) ──────────┐
#   │  MINIO_ENDPOINT=http://host.docker.internal:9000                           │
#   │  → presigned URL = http://host.docker.internal:9000/...                   │
#   │  → docling-serve résout host.docker.internal via extra_hosts (docker-compose)│
#   └────────────────────────────────────────────────────────────────────────────┘
#
#   ┌─ Production (tout dans Docker / Kubernetes) ──────────────────────────────┐
#   │  MINIO_ENDPOINT=http://minio:9000                                         │
#   │  → presigned URL = http://minio:9000/...  (hostname interne du service)   │
#   │  → docling-serve résout minio via le réseau Docker/K8s                    │
#   └────────────────────────────────────────────────────────────────────────────┘
#
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=hrflow-cvs

# ── Docling-serve (parsing PDF/DOCX → Markdown) ───────────────────────────────
# Démarrer via : docker compose up -d docling-serve
# Lancer manuellement : docker run -p 5001:5001 ds4sd/docling-serve:latest
DOCLING_URL=http://localhost:5001

# ── AI providers (fallback chain) ────────────────────────────────────────────
# Each provider can be disabled via `enabled: false` in application.yaml
# without removing the key. Leave blank to use the `dummy-*-key` default.
GROQ_API_KEY=
GOOGLE_AI_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
OPEN_ROUTER_API_KEY=
HF_API_KEY=
